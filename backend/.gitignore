# TerraLeaf Backend — .gitignore

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
*.whl

# ── Virtual environments ───────────────────────────────────────────────────────
venv/
.venv/
env/
.env/
ENV/
env.bak/
venv.bak/

# ── Environment files (never commit real secrets) ─────────────────────────────
.env
*.local

# ── Model weights (large binary files — manage via DVC, Git LFS, or cloud storage)
models/*.keras
models/*.h5
models/*.pb
models/*.tflite
# Allow the class index map and placeholder README
!models/class_indices.json
!models/.gitkeep

# ── OS / Editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── Type checking ─────────────────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
