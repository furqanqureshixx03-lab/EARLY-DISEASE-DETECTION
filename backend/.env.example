# TerraLeaf API — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual values.
#   cp .env.example .env
#
# IMPORTANT: Never commit your .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Application metadata
APP_NAME=TerraLeaf API
APP_ENV=development
APP_VERSION=1.0.0

# CORS — comma-separated list of allowed frontend origins.
# Add your production domain here when deploying.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Model asset paths — relative to the backend/ project root.
MODEL_PATH=models/model.keras
CLASS_MAP_PATH=models/class_indices.json

# AccuWeather API Key (free tier limited to 50 calls/day)
# Get a key at: https://developer.accuweather.com/
ACCUWEATHER_API_KEY=

